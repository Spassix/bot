# Token du bot Telegram (obtenu via @BotFather)
BOT_TOKEN=your_telegram_bot_token_here

# ID Telegram de l'administrateur principal
ADMIN_ID=your_telegram_user_id_here

# Chat ID du groupe d'administration (ex: -1001234567890)
ADMIN_CHAT_ID=-id_du_groupe_prive

# URL du panel admin de votre site (utilisé dans /admin)
SHOP_ADMIN_URL=https://votre-domaine.tld/admin

# Configuration Cloudflare (pour le développement local)
CLOUDFLARE_ACCOUNT_ID=your_cloudflare_account_id
CLOUDFLARE_DATABASE_ID=your_d1_database_id

# Mode de fonctionnement (polling pour VPS, webhook pour Cloudflare Workers)
BOT_MODE=polling

# Port pour le serveur HTTP (si mode polling)
PORT=3000